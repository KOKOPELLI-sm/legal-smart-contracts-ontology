<?xml version="1.0"?>
<Ontology xmlns="http://www.w3.org/2002/07/owl#"
    xml:base="http://example.org/smartcontracts"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:lkif="http://www.estrellaproject.org/lkif-core.owl#"
    ontologyIRI="http://example.org/smartcontracts">

    <!-- Imports LKIF ontologies -->
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/lkif-core.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/lkif-extended.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/lkif-rules.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/lkif-top.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/legal-action.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/legal-role.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/norm.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/action.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/expression.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/mereology.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/process.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/role.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/time.owl"/>
    <owl:imports rdf:resource="./ontologies/ontologies-bridging/time-modification.owl"/>

    <!-- Smart Contract Core Classes -->
    <owl:Class rdf:about="#SmartContract">
        <rdfs:label>Smart Contract</rdfs:label>
        <owl:equivalentClass rdf:resource="&lkif;Contract"/>
    </owl:Class>
    <owl:Class rdf:about="#Function"><rdfs:label>Function</rdfs:label></owl:Class>
    <owl:Class rdf:about="#PayableFunction">
        <rdfs:label>Payable Function</rdfs:label>
        <rdfs:subClassOf rdf:resource="#Function"/>
    </owl:Class>
    <owl:Class rdf:about="#MonetaryFunction">
        <rdfs:label>Monetary Function</rdfs:label>
        <rdfs:subClassOf rdf:resource="#Function"/>
    </owl:Class>
    <owl:Class rdf:about="#StateVariable"><rdfs:label>State Variable</rdfs:label></owl:Class>
    <owl:Class rdf:about="#MappingVariable">
        <rdfs:label>Mapping Variable</rdfs:label>
        <rdfs:subClassOf rdf:resource="#StateVariable"/>
    </owl:Class>
    <owl:Class rdf:about="#ArrayVariable">
        <rdfs:label>Array Variable</rdfs:label>
        <rdfs:subClassOf rdf:resource="#StateVariable"/>
    </owl:Class>
    <owl:Class rdf:about="#Struct"><rdfs:label>Struct</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Member"><rdfs:label>Member</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Parameter"><rdfs:label>Parameter</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Event"><rdfs:label>Event</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Modifier"><rdfs:label>Modifier</rdfs:label></owl:Class>

    <!-- LKIF Bridging Examples (expand as needed) -->
    <owl:Class rdf:about="#Agent">
        <rdfs:label>Agent</rdfs:label>
        <owl:equivalentClass rdf:resource="&lkif;Agent"/>
    </owl:Class>
    <owl:Class rdf:about="#LegalRole">
        <rdfs:label>Legal Role</rdfs:label>
        <owl:equivalentClass rdf:resource="&lkif;LegalRole"/>
    </owl:Class>
    <owl:Class rdf:about="#Obligation">
        <rdfs:label>Obligation</rdfs:label>
        <owl:equivalentClass rdf:resource="&lkif;Obligation"/>
    </owl:Class>
    <owl:Class rdf:about="#Norm">
        <rdfs:label>Norm</rdfs:label>
        <owl:equivalentClass rdf:resource="&lkif;Norm"/>
    </owl:Class>
    <owl:Class rdf:about="#Action">
        <rdfs:label>Action</rdfs:label>
        <owl:equivalentClass rdf:resource="&lkif;Action"/>
    </owl:Class>
    <owl:Class rdf:about="#Process">
        <rdfs:label>Process</rdfs:label>
        <owl:equivalentClass rdf:resource="&lkif;Process"/>
    </owl:Class>
    <owl:Class rdf:about="#Role">
        <rdfs:label>Role</rdfs:label>
        <owl:equivalentClass rdf:resource="&lkif;Role"/>
    </owl:Class>

    <!-- Object Properties -->
    <owl:ObjectProperty rdf:about="#hasFunction">
        <rdfs:domain rdf:resource="#SmartContract"/>
        <rdfs:range rdf:resource="#Function"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasVariable">
        <rdfs:domain rdf:resource="#SmartContract"/>
        <rdfs:range rdf:resource="#StateVariable"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasEvent">
        <rdfs:domain rdf:resource="#SmartContract"/>
        <rdfs:range rdf:resource="#Event"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasModifier">
        <rdfs:domain rdf:resource="#Function"/>
        <rdfs:range rdf:resource="#Modifier"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasStruct">
        <rdfs:domain rdf:resource="#SmartContract"/>
        <rdfs:range rdf:resource="#Struct"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasMember">
        <rdfs:domain rdf:resource="#Struct"/>
        <rdfs:range rdf:resource="#Member"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasParameter">
        <rdfs:domain rdf:resource="#Function"/>
        <rdfs:range rdf:resource="#Parameter"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasParameter">
        <rdfs:domain rdf:resource="#Event"/>
        <rdfs:range rdf:resource="#Parameter"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#readsVariable">
        <rdfs:domain rdf:resource="#Function"/>
        <rdfs:range rdf:resource="#StateVariable"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#writesVariable">
        <rdfs:domain rdf:resource="#Function"/>
        <rdfs:range rdf:resource="#StateVariable"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#inheritsFrom">
        <rdfs:domain rdf:resource="#SmartContract"/>
        <rdfs:range rdf:resource="#SmartContract"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#emitsEvent">
        <rdfs:domain rdf:resource="#Function"/>
        <rdfs:range rdf:resource="#Event"/>
    </owl:ObjectProperty>

    <!-- Datatype Properties -->
    <owl:DatatypeProperty rdf:about="#hasName">
        <rdfs:domain rdf:resource="#SmartContract"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasName">
        <rdfs:domain rdf:resource="#Function"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasName">
        <rdfs:domain rdf:resource="#StateVariable"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasName">
        <rdfs:domain rdf:resource="#Parameter"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasName">
        <rdfs:domain rdf:resource="#Event"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasName">
        <rdfs:domain rdf:resource="#Modifier"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasName">
        <rdfs:domain rdf:resource="#Struct"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasName">
        <rdfs:domain rdf:resource="#Member"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasType">
        <rdfs:domain rdf:resource="#StateVariable"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasType">
        <rdfs:domain rdf:resource="#Parameter"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasType">
        <rdfs:domain rdf:resource="#Member"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasType">
        <rdfs:domain rdf:resource="#Function"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasVisibility">
        <rdfs:domain rdf:resource="#StateVariable"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasVisibility">
        <rdfs:domain rdf:resource="#Function"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#isPayable">
        <rdfs:domain rdf:resource="#Function"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#isMonetaryValue">
        <rdfs:domain rdf:resource="#StateVariable"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#isMonetaryValue">
        <rdfs:domain rdf:resource="#Parameter"/>
        <rdfs:range rdf:resource="&xsd;boolean"/>
    </owl:DatatypeProperty>

    <!-- Example Restrictions (expand as needed) -->
    <owl:Class rdf:about="#SmartContract">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasFunction"/>
                <owl:minQualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="#Function"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    <owl:Class rdf:about="#Function">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasParameter"/>
                <owl:minQualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">0</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="#Parameter"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

</Ontology>
